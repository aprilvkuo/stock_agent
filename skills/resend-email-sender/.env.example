# Resend Email API Configuration
# Get your API key at: https://resend.com

# Required: Your Resend API key
RESEND_API_KEY=your_resend_api_key_here

# Optional: Default sender address (default: onboarding@resend.dev)
RESEND_FROM=your-verified@yourdomain.com

# Optional: Default recipient address
RESEND_TO=default-recipient@example.com
