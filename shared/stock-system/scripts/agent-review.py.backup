#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
复盘 Agent - 独立执行脚本
负责：验证预测、评估 Agent 表现、更新规则库
"""

import os
import sys
import json
from datetime import datetime, timedelta
import subprocess
import re

# 配置
WORKSPACE = '/Users/egg/.openclaw/workspace'
COORDINATOR_DIR = os.path.join(WORKSPACE, 'agents/stock-coordinator')
DATA_DIR = os.path.join(COORDINATOR_DIR, 'data')
VALIDATION_QUEUE = os.path.join(DATA_DIR, 'validation-queue.md')
STOCK_ANALYZER = os.path.join(WORKSPACE, 'skills/stock-analyzer-readonly/scripts/analyze_stock.py')
REPORTS_DIR = os.path.join(DATA_DIR, 'reports')
BACKUP_DIR = os.path.join(DATA_DIR, 'backups')

def get_stock_data(stock_code):
    """获取真实股价数据"""
    try:
        result = subprocess.run(
            ['python3', STOCK_ANALYZER, stock_code],
            capture_output=True, text=True, timeout=60
        )
        output = result.stdout
        
        data = {}
        price_match = re.search(r'当前股价：¥([\d.]+)', output)
        change_match = re.search(r'涨跌幅：([+-]?[\d.]+)%', output)
        
        if price_match:
            data['price'] = float(price_match.group(1))
        if change_match:
            data['change_pct'] = float(change_match.group(1))
        
        return data
    except Exception as e:
        print(f"获取数据失败：{e}")
        return None

def validate_predictions():
    """验证到期预测"""
    if not os.path.exists(VALIDATION_QUEUE):
        print("验证队列不存在")
        return
    
    with open(VALIDATION_QUEUE, 'r', encoding='utf-8') as f:
        content = f.read()
    
    lines = content.split('\n')
    today = datetime.now()
    validated_count = 0
    
    print(f"验证日期：{today.strftime('%Y-%m-%d')}\n")
    
    for i, line in enumerate(lines):
        if not line.strip().startswith('|') or '⏳ 待验证' not in line:
            continue
        
        parts = [p.strip() for p in line.split('|')]
        if len(parts) < 6:
            continue
        
        date = parts[1]  # 03-08
        stock_info = parts[2]  # 600519 茅台
        prediction = parts[3]  # 预测内容
        validate_date = parts[4]  # 04-08
        
        # 解析股票代码
        stock_match = re.search(r'(\d+)', stock_info)
        if not stock_match:
            continue
        stock_code = stock_match.group(1)
        
        # 检查是否到期
        try:
            validate_date_obj = datetime.strptime(f"2026-{validate_date}", '%Y-%m-%d')
        except:
            continue
        
        if validate_date_obj > today:
            remaining = (validate_date_obj - today).days
            print(f"⏳ {stock_info} - '{prediction}' 还有{remaining}天到期")
            continue
        
        # 到期了，获取真实数据验证
        print(f"\n🔍 验证：{stock_info}")
        print(f"   预测：{prediction}")
        
        data = get_stock_data(stock_code)
        if not data or 'price' not in data:
            print(f"   ❌ 获取数据失败")
            continue
        
        current_price = data['price']
        change = data.get('change_pct', 0)
        print(f"   当前价：¥{current_price} ({change:+.2f}%)")
        
        # 验证预测
        if '突破' in prediction:
            # 提取目标价
            price_match = re.search(r'¥([\d.]+)', prediction)
            if price_match:
                target = float(price_match.group(1))
                if current_price >= target:
                    status = "✅ 正确"
                    analysis = f"当前价{current_price}元已突破目标{target}元"
                else:
                    status = "❌ 错误"
                    gap = (target - current_price) / target * 100
                    analysis = f"当前价{current_price}元，距离目标{target}元还差{gap:.1f}%"
                
                print(f"   状态：{status}")
                print(f"   分析：{analysis}")
                
                # 更新状态
                lines[i] = line.replace('⏳ 待验证', status.split()[0])
                validated_count += 1
        
        elif '跌破' in prediction or '不跌破' in prediction:
            # 提取止损价
            price_match = re.search(r'¥([\d.]+)', prediction)
            if price_match:
                stop = float(price_match.group(1))
                if current_price >= stop:
                    status = "✅ 正确"
                    safety = (current_price - stop) / stop * 100
                    analysis = f"当前价{current_price}元，距离止损位{stop}元有{safety:.1f}%安全边际"
                else:
                    status = "❌ 错误"
                    analysis = f"当前价{current_price}元已跌破止损位{stop}元"
                
                print(f"   状态：{status}")
                print(f"   分析：{analysis}")
                
                lines[i] = line.replace('⏳ 待验证', status.split()[0])
                validated_count += 1
    
    # 写回文件
    with open(VALIDATION_QUEUE, 'w', encoding='utf-8') as f:
        f.write('\n'.join(lines))
    
    print(f"\n{'='*50}")
    if validated_count == 0:
        print("本次无到期需要验证的预测")
    else:
        print(f"完成 {validated_count} 项验证")
    print(f"{'='*50}\n")

def generate_weekly_report():
    """生成周度复盘报告"""
    os.makedirs(REPORTS_DIR, exist_ok=True)
    
    today = datetime.now()
    week_num = today.isocalendar()[1]
    year = today.year
    
    report_file = os.path.join(REPORTS_DIR, f"{year}-W{week_num:02d}-weekly-review.md")
    
    # 统计本周分析
    requests_dir = os.path.join(SHARED_DIR, 'queue/requests')
    analysis_count = 0
    
    if os.path.exists(requests_dir):
        for f in os.listdir(requests_dir):
            if f.endswith('.md') and f.startswith(today.strftime('%Y%m%d')):
                analysis_count += 1
    
    # 统计验证
    validated_count = 0
    correct_count = 0
    
    if os.path.exists(VALIDATION_QUEUE):
        with open(VALIDATION_QUEUE, 'r', encoding='utf-8') as f:
            content = f.read()
            validated_count = content.count('✅')
            correct_count = content.count('✅')
    
    # 生成报告
    report = f"""# 周度复盘报告

## 报告周期
{year}-W{week_num:02d} ({today.strftime('%Y-%m-%d')})

---

## 本周概览

| 指标 | 数值 |
|------|------|
| 分析次数 | {analysis_count} |
| 已验证预测 | {validated_count} |
| 正确预测 | {correct_count} |
| 准确率 | {correct_count/validated_count*100:.1f}% if validated_count > 0 else 'N/A' |

---

## Agent 表现

_(待各 Agent 独立报告)_

---

## 规则库状态

- 当前版本：v1.0
- 本周新增规则：0 条
- 本周废弃规则：0 条

---

## 改进建议

_(待积累数据后生成)_

---

**复盘 Agent-v1.0** 生成
"""
    
    with open(report_file, 'w', encoding='utf-8') as f:
        f.write(report)
    
    print(f"✅ 周度报告已生成：{report_file}")

def main():
    if len(sys.argv) < 2:
        print("用法：python3 agent-review.py <daily|weekly|monthly>")
        return
    
    action = sys.argv[1].lower()
    
    print(f"\n{'='*50}")
    print(f"🔄 复盘 Agent - {action}")
    print(f"{'='*50}\n")
    
    if action == 'daily':
        validate_predictions()
    elif action == 'weekly':
        generate_weekly_report()
    elif action == 'monthly':
        print("月度迭代功能待实现...")
    else:
        print(f"未知动作：{action}")
    
    print(f"\n{'='*50}")
    print(f"✅ 复盘 Agent 执行完成")
    print(f"{'='*50}\n")

if __name__ == '__main__':
    main()
