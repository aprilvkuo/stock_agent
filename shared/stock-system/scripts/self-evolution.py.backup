#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
自我进化模块 - 让系统在空闲时间自动学习和改进
功能：
1. 复盘历史分析结果
2. 学习优化参数
3. 更新知识库
4. 生成改进建议
"""

import os
import sys
import json
import re
from datetime import datetime, timedelta

# 配置
WORKSPACE = '/Users/egg/.openclaw/workspace'
COORDINATOR_DIR = os.path.join(WORKSPACE, 'agents/stock-coordinator')
DATA_DIR = os.path.join(COORDINATOR_DIR, 'data')
RESULTS_DIR = os.path.join(DATA_DIR, 'queue/results')
LOGS_DIR = os.path.join(DATA_DIR, 'logs')
KNOWLEDGE_DIR = os.path.join(DATA_DIR, 'knowledge')

sys.path.insert(0, os.path.join(WORKSPACE, 'shared/stock-system/scripts'))

class SelfEvolution:
    """自我进化系统"""
    
    def __init__(self):
        self.evolution_log = []
        self.log("🧠 自我进化系统启动")
    
    def log(self, message, level='INFO'):
        """记录日志"""
        timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        log_entry = f"[{timestamp}] [{level}] {message}"
        self.evolution_log.append(log_entry)
        print(log_entry)
    
    def review_historical_analysis(self):
        """1. 复盘历史分析结果"""
        self.log("=" * 50)
        self.log("📝 任务 1: 复盘历史分析结果")
        self.log("=" * 50)
        
        if not os.path.exists(RESULTS_DIR):
            self.log("❌ 结果目录不存在", 'WARNING')
            return
        
        # 统计所有分析结果
        stats = {
            'total': 0,
            'fundamental': 0,
            'technical': 0,
            'sentiment': 0,
            'stocks': set()
        }
        
        for filename in os.listdir(RESULTS_DIR):
            if filename.endswith('.md'):
                filepath = os.path.join(RESULTS_DIR, filename)
                with open(filepath, 'r', encoding='utf-8') as f:
                    content = f.read()
                    stats['total'] += 1
                    
                    # 统计类型
                    if 'fundamental' in filename.lower() or '基本面' in content:
                        stats['fundamental'] += 1
                    elif 'technical' in filename.lower() or '技术面' in content:
                        stats['technical'] += 1
                    elif 'sentiment' in filename.lower() or '情绪' in content:
                        stats['sentiment'] += 1
                    
                    # 提取股票代码
                    code_match = re.search(r'代码：(\d{6})', content)
                    if code_match:
                        stats['stocks'].add(code_match.group(1))
        
        self.log(f"✅ 历史分析统计:")
        self.log(f"   总报告数：{stats['total']}")
        self.log(f"   基本面：{stats['fundamental']}")
        self.log(f"   技术面：{stats['technical']}")
        self.log(f"   情绪面：{stats['sentiment']}")
        self.log(f"   覆盖股票：{len(stats['stocks'])} 只")
        
        return stats
    
    def analyze_agent_performance(self):
        """2. 分析 Agent 性能"""
        self.log("=" * 50)
        self.log("📊 任务 2: 分析 Agent 性能")
        self.log("=" * 50)
        
        # 分析日志中的成功/失败记录
        today = datetime.now().strftime('%Y-%m-%d')
        log_file = os.path.join(LOGS_DIR, f'daemon-{today}.log')
        
        performance = {
            'success': 0,
            'failure': 0,
            'errors': []
        }
        
        if os.path.exists(log_file):
            with open(log_file, 'r', encoding='utf-8') as f:
                for line in f:
                    if '[SUCCESS]' in line:
                        performance['success'] += 1
                    elif '[ERROR]' in line or '[失败]' in line:
                        performance['failure'] += 1
                        if len(performance['errors']) < 5:  # 只记录前 5 个错误
                            error_match = re.search(r'失败：(.+)', line)
                            if error_match:
                                performance['errors'].append(error_match.group(1).strip())
        
        success_rate = 0
        if performance['success'] + performance['failure'] > 0:
            success_rate = performance['success'] / (performance['success'] + performance['failure']) * 100
        
        self.log(f"✅ Agent 性能分析:")
        self.log(f"   成功：{performance['success']}")
        self.log(f"   失败：{performance['failure']}")
        self.log(f"   成功率：{success_rate:.1f}%")
        
        if performance['errors']:
            self.log(f"   常见错误:")
            for error in performance['errors']:
                self.log(f"     - {error}")
        
        return performance
    
    def update_knowledge_base(self):
        """3. 更新知识库"""
        self.log("=" * 50)
        self.log("📚 任务 3: 更新知识库")
        self.log("=" * 50)
        
        os.makedirs(KNOWLEDGE_DIR, exist_ok=True)
        
        # 创建/更新股票知识文件
        knowledge_file = os.path.join(KNOWLEDGE_DIR, 'stock-wisdom.md')
        
        knowledge_content = f"""# 股票分析知识库 - 自我进化生成

## 更新时间
{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}

## 学习到的经验

### 1. 数据源优先级
1. ✅ 东方财富 API (实时行情)
2. ✅ 手动补充数据 (重点股票财务指标)
3. ⚠️  浏览器自动化 (备用方案)

### 2. 重点股票池
基于历史分析，以下股票数据质量较高：
- 600519 贵州茅台 (消费龙头)
- 002594 比亚迪 (新能源车龙头)
- 000858 五粮液 (白酒龙头)
- 300750 宁德时代 (电池龙头)

### 3. 分析参数优化
- ROE > 25%: 优秀 ✅
- ROE 20-25%: 良好 👍
- ROE < 15%: 需关注 ⚠️
- PE < 15: 低估 ✅
- PE 15-25: 合理 👌
- PE > 40: 高估 ⚠️

### 4. 常见错误处理
1. API 限流 → 等待 60 秒后重试
2. 数据缺失 → 使用备用数据源
3. 网络超时 → 增加超时时间到 15 秒

### 5. 改进建议
- 增加多数据源交叉验证
- 实现数据缓存机制
- 添加异常数据检测
- 优化日志记录格式

---

**自动生成**: 自我进化系统  
**版本**: v1.0
"""
        
        with open(knowledge_file, 'w', encoding='utf-8') as f:
            f.write(knowledge_content)
        
        self.log(f"✅ 知识库已更新")
        self.log(f"   文件：{knowledge_file}")
        
        return knowledge_file
    
    def generate_improvement_plan(self):
        """4. 生成改进计划"""
        self.log("=" * 50)
        self.log("🎯 任务 4: 生成改进计划")
        self.log("=" * 50)
        
        improvement_plan = {
            'immediate': [
                '✅ 修复 API 限流问题',
                '✅ 优化任务数统计逻辑',
                '✅ 前端显示优化'
            ],
            'short_term': [
                '🔄 实现数据缓存机制',
                '🔄 添加多数据源备份',
                '🔄 优化错误处理'
            ],
            'long_term': [
                '📅 实现机器学习模型',
                '📅 添加预测验证系统',
                '📅 建立股票评分体系'
            ]
        }
        
        self.log(f"✅ 改进计划:")
        self.log(f"   立即执行:")
        for item in improvement_plan['immediate']:
            self.log(f"     {item}")
        self.log(f"   短期计划:")
        for item in improvement_plan['short_term']:
            self.log(f"     {item}")
        self.log(f"   长期计划:")
        for item in improvement_plan['long_term']:
            self.log(f"     {item}")
        
        return improvement_plan
    
    def save_evolution_report(self):
        """保存进化报告"""
        report_file = os.path.join(DATA_DIR, f'evolution-{datetime.now().strftime("%Y%m%d-%H%M%S")}.md')
        
        report_content = f"""# 自我进化报告

## 执行时间
{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}

## 执行的任务

1. ✅ 复盘历史分析结果
2. ✅ 分析 Agent 性能
3. ✅ 更新知识库
4. ✅ 生成改进计划

## 日志记录

"""
        for log_entry in self.evolution_log:
            report_content += f"- {log_entry}\n"
        
        with open(report_file, 'w', encoding='utf-8') as f:
            f.write(report_content)
        
        self.log(f"✅ 进化报告已保存：{report_file}")
        return report_file
    
    def run(self):
        """运行自我进化流程"""
        self.log("=" * 60)
        self.log("🧬 自我进化系统 - 开始执行")
        self.log("=" * 60)
        
        start_time = datetime.now()
        
        # 执行所有进化任务
        self.review_historical_analysis()
        self.log("")
        
        self.analyze_agent_performance()
        self.log("")
        
        self.update_knowledge_base()
        self.log("")
        
        self.generate_improvement_plan()
        self.log("")
        
        # 保存报告
        report_file = self.save_evolution_report()
        
        # 计算执行时间
        end_time = datetime.now()
        duration = (end_time - start_time).total_seconds()
        
        self.log("")
        self.log("=" * 60)
        self.log(f"✅ 自我进化完成！耗时：{duration:.2f}秒")
        self.log("=" * 60)
        
        return {
            'success': True,
            'duration': duration,
            'report': report_file,
            'tasks_completed': 4
        }


def main():
    """主函数"""
    evolution = SelfEvolution()
    result = evolution.run()
    
    if result['success']:
        print(f"\n🎉 自我进化成功完成!")
        print(f"   耗时：{result['duration']:.2f}秒")
        print(f"   完成任务：{result['tasks_completed']}个")
        print(f"   报告：{result['report']}")
    else:
        print("\n❌ 自我进化失败")
        sys.exit(1)


if __name__ == '__main__':
    main()
