def get_market_name(market_type):
    """获取市场名称"""
    names = {'A': 'A 股', 'HK': '港股', 'US': '美股'}
    return names.get(market_type, market_type)

def get_stock_code_format(market_type):
    """获取股票代码格式说明"""
    formats = {
        'A': '6 位数字（如 600519）',
        'HK': '5 位数字（如 00700）',
        'US': '1-5 位字母（如 AAPL）'
    }
    return formats.get(market_type, '')


# ============ 原有模块 ============

@app.route('/api/logs')
def api_logs():
    """API - 获取活动日志"""
    logs = []
    
    if not os.path.exists(LOGS_DIR):
        return jsonify(logs)
    
    agent_patterns = {
        '基本面 Agent': {'emoji': '📊', 'color': 'text-blue-400'},
        '技术面 Agent': {'emoji': '📈', 'color': 'text-purple-400'},
        '情绪 Agent': {'emoji': '😊', 'color': 'text-pink-400'},
        '主 Agent': {'emoji': '🎯', 'color': 'text-green-400'},
        '复盘 Agent': {'emoji': '📝', 'color': 'text-orange-400'}
    }
    
    # 扫描最近的日志文件
    now = datetime.now()
    log_files = sorted(
        [f for f in os.listdir(LOGS_DIR) if f.endswith('.md')],
        reverse=True
    )[:10]  # 只读取最近 10 个文件
    
    for filename in log_files:
        filepath = os.path.join(LOGS_DIR, filename)
        try:
            with open(filepath, 'r', encoding='utf-8') as f:
                content = f.read()
                
                # 提取时间戳
                time_match = re.search(r'(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})', content)
                if time_match:
                    timestamp = time_match.group(1)
                    
                    # 识别 Agent
                    for agent_name, info in agent_patterns.items():
                        if agent_name in content:
                            # 提取关键信息
                            stock_match = re.search(r'股票代码：(\d+)', content)
                            name_match = re.search(r'股票名称：(.+)', content)
                            
                            stock_code = stock_match.group(1) if stock_match else ''
                            stock_name = name_match.group(1).strip() if name_match else ''
                            
                            # 判断任务类型
                            if '分析结果' in content or '评级' in content:
                                message = f'完成分析：{stock_code} {stock_name}'
                            elif '验证' in content:
                                message = f'执行验证：{stock_code} {stock_name}'
                            else:
                                message = f'处理任务：{stock_code} {stock_name}'
                            
                            logs.append({
                                'time': timestamp,
                                'agent': agent_name,
                                'emoji': info['emoji'],
                                'color': info['color'],
                                'message': message
                            })
                            break
        except Exception:
            pass
    
    # 按时间排序，最新的在前
    logs.sort(key=lambda x: x['time'], reverse=True)
    
    return jsonify(logs[:20])  # 返回最近 20 条

@app.route('/api/agent-todos')
def api_agent_todos():
    """API - 获取所有 Agent TODO list"""
    try:
        todos = get_all_todos()
        return jsonify(todos)
    except Exception as e:
        return jsonify({'error': str(e)}), 500

@app.route('/api/latest-meeting')
def api_latest_meeting():
    """API - 获取最新会议纪要"""
    try:
        meeting = get_latest_meeting()
        return jsonify(meeting)
    except Exception as e:
        return jsonify({'error': str(e)}), 500

@app.route('/agent-meetings')
def agent_meetings_page():
    """Agent 例会页面"""
    return render_template('agent-meetings.html')

