@app.route('/api/report/<stock_code>')
def api_report(stock_code):
    """API - 获取股票详细分析报告"""
    reports = {'fundamental': None, 'technical': None, 'sentiment': None}
    report_contents = {}
    stock_info = None
    
    # 1. 查找请求文件获取股票信息
    if os.path.exists(REQUESTS_DIR):
        for f in os.listdir(REQUESTS_DIR):
            if f.endswith('.md'):
                req_data = parse_request_file(os.path.join(REQUESTS_DIR, f))
                if req_data and req_data.get('code') == stock_code:
                    stock_info = {
                        'code': stock_code,
                        'name': req_data.get('name', 'N/A'),
                        'request_time': req_data.get('request_time', 'N/A'),
                        'status': req_data.get('status', 'N/A')
                    }
                    break
    
    # 2. 通过内容查找该股票的结果文件
    if os.path.exists(RESULTS_DIR):
        for f in os.listdir(RESULTS_DIR):
            if f.endswith('.md'):
                filepath = os.path.join(RESULTS_DIR, f)
                try:
                    with open(filepath, 'r', encoding='utf-8') as file:
                        content = file.read()
                        # 检查是否包含该股票代码
                        if f'代码：{stock_code}' in content or f'code": "{stock_code}"' in content:
                            result_data = parse_result_file(filepath)
                            
                            # 判断类型
                            if 'fundamental' in f.lower() or '基本面' in content:
                                reports['fundamental'] = result_data
                                report_contents['fundamental'] = content
                            elif 'technical' in f.lower() or '技术面' in content:
                                reports['technical'] = result_data
                                report_contents['technical'] = content
                            elif 'sentiment' in f.lower() or '情绪' in content:
                                reports['sentiment'] = result_data
                                report_contents['sentiment'] = content
                except Exception:
                    pass
    
    return jsonify({
        'stock': stock_info,
        'reports': reports,
        'contents': report_contents
    })

@app.route('/report/<stock_code>')
def report_page(stock_code):
    """详细报告页面"""
    return render_template('report.html', stock_code=stock_code)

@app.route('/api/evolution')
def api_evolution():
    """API - 获取进化报告列表"""
    evolution_reports = []
    
    # 扫描进化报告目录
    if os.path.exists(DATA_DIR):
        for filename in sorted(os.listdir(DATA_DIR), reverse=True):
            if filename.startswith('evolution-') and filename.endswith('.md'):
                filepath = os.path.join(DATA_DIR, filename)
                try:
                    with open(filepath, 'r', encoding='utf-8') as f:
                        content = f.read()
                        
                        # 提取基本信息
                        time_match = re.search(r'## 更新时间\s+(.+)', content)
                        exec_time = time_match.group(1).strip() if time_match else filename
                        
                        # 提取统计数据
                        total_match = re.search(r'总报告数：(\d+)', content)
                        success_match = re.search(r'成功：(\d+)', content)
                        rate_match = re.search(r'成功率：([\d.]+)%', content)
                        
                        evolution_reports.append({
                            'filename': filename,
                            'time': exec_time,
                            'total_reports': int(total_match.group(1)) if total_match else 0,
                            'success_count': int(success_match.group(1)) if success_match else 0,
                            'success_rate': float(rate_match.group(1)) if rate_match else 0,
                            'preview': content[:500] + '...' if len(content) > 500 else content
                        })
                except Exception as e:
                    print(f"读取进化报告失败：{e}")
    
    return jsonify({
        'reports': evolution_reports,
        'count': len(evolution_reports)
    })

@app.route('/evolution')
def evolution_page():
    """进化报告页面"""
    return render_template('evolution.html')

@app.route('/api/evolution/<filename>')
def api_evolution_detail(filename):
    """API - 获取进化报告详情"""
    filepath = os.path.join(DATA_DIR, filename)
    
    if not os.path.exists(filepath):
        return jsonify({'error': '报告不存在'}), 404
    
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            content = f.read()
        
        return jsonify({
            'filename': filename,
            'content': content,
            'html': content  # 前端会用 marked.js 渲染
        })
    except Exception as e:
        return jsonify({'error': str(e)}), 500

