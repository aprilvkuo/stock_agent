@app.route('/api/holdings', methods=['GET'])
def api_get_holdings():
    """API - 获取持仓列表"""
    status = request.args.get('status', 'active')
    holdings = holdings_manager.get_holdings(status)
    summary = holdings_manager.get_summary()
    
    return jsonify({
        'holdings': holdings,
        'summary': summary,
    })

@app.route('/api/holdings', methods=['POST'])
def api_add_holding():
    """API - 添加持仓"""
    data = request.json
    
    # 验证必填字段
    required = ['stock_code', 'stock_name', 'shares', 'cost_price']
    for field in required:
        if field not in data:
            return jsonify({'success': False, 'error': f'缺少必填字段：{field}'}), 400
    
    # 自动判断市场类型（如果未提供）
    market_type = data.get('market_type')
    if not market_type:
        market_type = parse_stock_code_format(data['stock_code'])
        if not market_type:
            market_type = 'A'  # 默认 A 股
    
    # 验证股票代码格式
    if not validate_stock_code(data['stock_code'], market_type):
        return jsonify({
            'success': False, 
            'error': f'股票代码格式不正确（{get_market_name(market_type)}应为{get_stock_code_format(market_type)}）'
        }), 400
    
    try:
        holding = holdings_manager.add_holding(
            stock_code=data['stock_code'],
            stock_name=data['stock_name'],
            shares=float(data['shares']),
            cost_price=float(data['cost_price']),
            market_type=market_type,
            notes=data.get('notes', '')
        )
        
        return jsonify({'success': True, 'holding': holding})
    except Exception as e:
        return jsonify({'success': False, 'error': str(e)}), 500

@app.route('/api/holdings/<holding_id>', methods=['GET'])
def api_get_holding(holding_id):
    """API - 获取单个持仓"""
    holding = holdings_manager.get_holding_by_id(holding_id)
    
    if not holding:
        return jsonify({'error': '持仓不存在'}), 404
    
    return jsonify(holding)

@app.route('/api/holdings/<holding_id>', methods=['PUT'])
def api_update_holding(holding_id):
    """API - 更新持仓"""
    data = request.json
    
    # 允许更新的字段
    allowed_fields = ['stock_name', 'shares', 'cost_price', 'notes', 'status']
    updates = {k: v for k, v in data.items() if k in allowed_fields}
    
    if not updates:
        return jsonify({'success': False, 'error': '没有可更新的字段'}), 400
    
    holding = holdings_manager.update_holding(holding_id, **updates)
    
    if not holding:
        return jsonify({'success': False, 'error': '持仓不存在'}), 404
    
    return jsonify({'success': True, 'holding': holding})

@app.route('/api/holdings/<holding_id>', methods=['DELETE'])
def api_delete_holding(holding_id):
    """API - 删除持仓"""
    success = holdings_manager.delete_holding(holding_id)
    
    if not success:
        return jsonify({'success': False, 'error': '持仓不存在'}), 404
    
    return jsonify({'success': True})

