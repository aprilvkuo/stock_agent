# 数据目录
DATA_DIR = '/Users/egg/.openclaw/workspace/agents/stock-coordinator/data'
LOGS_DIR = os.path.join(DATA_DIR, 'logs')
REQUESTS_DIR = os.path.join(DATA_DIR, 'queue/requests')
RESULTS_DIR = os.path.join(DATA_DIR, 'queue/results')

def parse_markdown_file(filepath):
    """解析 Markdown 文件内容"""
    if not os.path.exists(filepath):
        return None
    
    with open(filepath, 'r', encoding='utf-8') as f:
        return f.read()

def parse_request_file(filepath):
    """解析请求文件"""
    content = parse_markdown_file(filepath)
    if not content:
        return None
    
    data = {}
    
    # 提取股票代码
    stock_match = re.search(r'股票代码：(\d+)', content)
    if stock_match:
        data['code'] = stock_match.group(1)
    
    # 提取股票名称
    name_match = re.search(r'股票名称：(.+)', content)
    if name_match:
        data['name'] = name_match.group(1).strip()
    
    # 提取请求时间
    time_match = re.search(r'请求时间：(.+)', content)
    if time_match:
        data['request_time'] = time_match.group(1).strip()
    
    # 提取状态
    status_match = re.search(r'汇总：✅ 已完成 - (.+)', content)
    if status_match:
        data['status'] = status_match.group(1).strip()
    else:
        status_match = re.search(r'汇总：(.+)', content)
        if status_match:
            data['status'] = status_match.group(1).strip()
    
    return data

def parse_result_file(filepath):
    """解析结果文件"""
    content = parse_markdown_file(filepath)
    if not content:
        return None
    
    data = {}
    
    # 提取评级
    rating_match = re.search(r'\| 评级 \| (.+?) \|', content)
    if rating_match:
        data['rating'] = rating_match.group(1).strip()
    
    # 提取置信度
    confidence_match = re.search(r'\| 置信度 \| (\d+)%', content)
    if confidence_match:
        data['confidence'] = int(confidence_match.group(1))
    
    # 提取建议
    suggestion_match = re.search(r'\| 建议 \| (.+)', content)
    if suggestion_match:
        data['suggestion'] = suggestion_match.group(1).strip()
    
    # 判断类型
    if 'fundamental' in filepath.lower() or '基本面' in content:
        data['type'] = 'fundamental'
    elif 'technical' in filepath.lower() or '技术面' in content:
        data['type'] = 'technical'
    elif 'sentiment' in filepath.lower() or '情绪' in content:
        data['type'] = 'sentiment'
    else:
        data['type'] = 'unknown'
    
    return data

def parse_validation_queue():
    """解析验证队列"""
    filepath = os.path.join(DATA_DIR, 'validation-queue.md')
    content = parse_markdown_file(filepath)
    if not content:
        return {'pending': [], 'correct': 0, 'wrong': 0}
    
    items = []
    correct = content.count('✅ 正确')
    wrong = content.count('❌ 错误')
    
    # 提取待验证项
    for line in content.split('\n'):
        if '⏳ 待验证' in line:
            parts = [p.strip() for p in line.split('|')]
            if len(parts) >= 5:
                items.append({
                    'stock': parts[2],
                    'prediction': parts[3],
                    'date': parts[4].strip(),
                    'status': 'pending'
                })
    
    # 提取已验证项
    for line in content.split('\n'):
        if '✅ 正确' in line or '❌ 错误' in line:
            parts = [p.strip() for p in line.split('|')]
            if len(parts) >= 5:
                status = 'correct' if '✅ 正确' in line else 'wrong'
                items.append({
                    'stock': parts[2],
                    'prediction': parts[3],
                    'date': parts[4].strip(),
                    'verified_date': parts[5].strip() if len(parts) > 5 else '',
                    'status': status
                })
    
    return {
        'items': items,
        'pending': len([i for i in items if i['status'] == 'pending']),
        'correct': correct,
        'wrong': wrong
    }

def check_recent_activity(agent_name_pattern, hours=24):
    """检查最近 Agent 活动 - 优化版：只统计今日完成的唯一股票数"""
    now = datetime.now()
    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)
    last_run = None
    unique_stocks = set()  # 使用集合去重 (按股票代码)
    
    # 1. 检查守护进程日志 (只读今日日志)
    today_log = os.path.join(LOGS_DIR, f'daemon-{today_start.strftime("%Y-%m-%d")}.log')
    if os.path.exists(today_log):
        try:
            with open(today_log, 'r', encoding='utf-8') as f:
                lines = f.readlines()
                for line in lines:
                    # 只统计成功的 Agent 完成记录
                    if 'SUCCESS' in line and 'Agent 完成' in line:
                        if re.search(agent_name_pattern, line) or re.search(agent_name_pattern.replace('Agent', ''), line):
                            # 提取股票代码
                            stock_match = re.search(r'(\d{6})', line)
                            if stock_match:
                                unique_stocks.add(stock_match.group(1))
                            
                            # 提取时间戳
                            time_match = re.search(r'\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\]', line)
                            if time_match:
                                try:
                                    timestamp = datetime.strptime(time_match.group(1), '%Y-%m-%d %H:%M:%S')
                                    if last_run is None or timestamp > last_run:
                                        last_run = timestamp
                                except Exception:
                                    pass
        except Exception:
            pass
    
    # 2. 检查结果文件 (只统计今日修改的)
    if os.path.exists(RESULTS_DIR):
        for filename in os.listdir(RESULTS_DIR):
            if filename.endswith('.md'):
                filepath = os.path.join(RESULTS_DIR, filename)
                try:
                    mtime = datetime.fromtimestamp(os.path.getmtime(filepath))
                    if mtime >= today_start:  # 今日修改的文件
                        with open(filepath, 'r', encoding='utf-8') as f:
                            content = f.read()
                            if re.search(agent_name_pattern, content) or re.search(agent_name_pattern.replace('Agent', ''), content):
                                # 提取股票代码
                                code_match = re.search(r'代码：(\d{6})', content)
                                if code_match:
                                    unique_stocks.add(code_match.group(1))
                                
                                if last_run is None or mtime > last_run:
                                    last_run = mtime
                except Exception:
                    pass
    
    return {
        'active': last_run is not None and (now - last_run) < timedelta(minutes=10),
        'last_run': last_run.strftime('%Y-%m-%d %H:%M:%S') if last_run else None,
        'count': len(unique_stocks)  # 返回唯一股票数
    }
    
def get_agent_status():
    """获取 Agent 实时状态"""
    agents_config = {
        'fundamental': {
            'name': '基本面 Agent',
            'pattern': r'基本面 Agent|fundamental'
        },
        'technical': {
            'name': '技术面 Agent',
            'pattern': r'技术面 Agent|technical'
        },
        'sentiment': {
            'name': '情绪 Agent',
            'pattern': r'情绪 Agent|sentiment'
        },
        'coordinator': {
            'name': '主 Agent',
            'pattern': r'主 Agent|Coordinator|coordinator'
        },
        'qa': {
            'name': '质检 Agent',
            'pattern': r'质检 Agent|qa|quality'
        },
        'programmer': {
            'name': '程序员 Agent',
            'pattern': r'程序员 Agent|programmer'
        }
    }
    
    result = {}
    now = datetime.now()
    
    for agent_id, config in agents_config.items():
        activity = check_recent_activity(config['pattern'])
        
        # 判断状态
        if activity['active']:
            status = 'active'
            emoji = '🟢'
            status_text = '运行中'
        elif activity['last_run']:
            # 检查最后运行时间
            try:
                last_run = datetime.strptime(activity['last_run'], '%Y-%m-%d %H:%M:%S')
                hours_ago = (now - last_run).total_seconds() / 3600
                
                if hours_ago < 1:
                    status = 'idle'
                    emoji = '🟡'
                    status_text = '空闲'
                elif hours_ago < 24:
                    status = 'idle'
                    emoji = '🟡'
                    status_text = f'{int(hours_ago)}小时前'
                else:
                    status = 'offline'
                    emoji = '🔴'
                    status_text = f'{int(hours_ago/24)}天前'
            except Exception:
                status = 'unknown'
                emoji = '⚪'
                status_text = '未知'
        else:
            status = 'offline'
            emoji = '🔴'
            status_text = '未活动'
        
        result[agent_id] = {
            'name': config['name'],
            'status': status,
            'emoji': emoji,
            'text': status_text,
            'last_run': activity['last_run'],
            'tasks': activity['count']
        }
    
    return result

def get_system_data():
    """获取系统数据"""
    # 获取所有请求
    requests = {}
    if os.path.exists(REQUESTS_DIR):
        for f in os.listdir(REQUESTS_DIR):
            if f.endswith('.md'):
                req_id = f.replace('.md', '')
                req_data = parse_request_file(os.path.join(REQUESTS_DIR, f))
                if req_data:
                    requests[req_id] = req_data
                    requests[req_id]['id'] = req_id
                    requests[req_id]['agents'] = {}
    
    # 获取所有结果并关联到请求
    if os.path.exists(RESULTS_DIR):
        for f in os.listdir(RESULTS_DIR):
            if f.endswith('.md'):
                result_data = parse_result_file(os.path.join(RESULTS_DIR, f))
                if result_data:
                    # 从文件名提取请求 ID
                    match = re.search(r'result_(.+?)_(fundamental|technical|sentiment)', f)
                    if match:
                        req_id = match.group(1)
                        agent_type = match.group(2)
                        if req_id in requests:
                            requests[req_id]['agents'][agent_type] = result_data
    
    # 转换为列表并排序
    analysis_list = sorted(
        [r for r in requests.values() if r.get('code')],
        key=lambda x: x.get('request_time', ''),
        reverse=True
    )
    
    # 获取验证队列
    validation = parse_validation_queue()
    
    # 获取 Agent 状态
    agent_status = get_agent_status()
    
    return {
        'analysis': analysis_list,
        'validation': validation,
        'agents': agent_status,
        'last_update': datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    }

