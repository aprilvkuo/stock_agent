# GitHub API 配置
# 生成方式：https://github.com/settings/tokens (Fine-grained tokens)
# 权限：issues (read/write), contents (read/write), pull_requests (read/write)

GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=aprilvkuo/stock_agent
GITHUB_BRANCH=main

# Agent GitHub 身份映射
# 格式：agent_id=github_username
AGENT_GITHUB_fundamental=fundamental-agent
AGENT_GITHUB_technical=technical-agent
AGENT_GITHUB_sentiment=sentiment-agent
AGENT_GITHUB_coordinator=coordinator-agent
AGENT_GITHUB_programmer=programmer-agent
AGENT_GITHUB_data-fetcher=data-fetcher-agent
AGENT_GITHUB_qa=qa-agent
AGENT_GITHUB_cio=cio-agent

# Issue 配置
GITHUB_ISSUE_LABELS=bug,enhancement,high-priority,critical
GITHUB_ISSUE_MILESTONE=v2.0

# PR 配置
GITHUB_PR_REVIEWERS=coordinator-agent,qa-agent
GITHUB_PR_AUTO_MERGE=false
